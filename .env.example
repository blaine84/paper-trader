# Finnhub API key (free tier: https://finnhub.io)
FINNHUB_API_KEY=your_key_here

# LLM provider — pick one
OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# Which LLM to use: openai | anthropic | mistral | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Low-effort tier (used when agents pass tier="low")
# Defaults to LLM_PROVIDER/LLM_MODEL if not set
# LLM_LOW_PROVIDER=mistral
# LLM_LOW_MODEL=mistral-small-latest
# MISTRAL_API_KEY=your_key_here

# Ollama (local) — only needed if using ollama as low provider
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Starting paper balance
STARTING_BALANCE=100000

# Watchlist (comma-separated)
WATCHLIST=SPY,QQQ,IWM,TSLA,NVDA,AMD

# How often the intraday loop runs (minutes)
LOOP_INTERVAL_MINUTES=15

# Web dashboard port
WEB_PORT=5000
