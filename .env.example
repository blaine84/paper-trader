FINNHUB_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Free Alpaca market data defaults to IEX. Use sip only with a paid data plan.
ALPACA_DATA_FEED=iex

# Postgres connection (leave commented for SQLite fallback)
# DATABASE_URL=postgresql+psycopg://paper_trader:password@127.0.0.1:5432/paper_trader

ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

LLM_LOW_PROVIDER=ollama
LLM_LOW_MODEL=mistral:latest
LLM_MED_PROVIDER=ollama
LLM_MED_MODEL=llama3.1:8b
OLLAMA_BASE_URL=
OLLAMA_TIMEOUT=300
OLLAMA_NUM_CTX=8192
OLLAMA_FALLBACK_PROVIDER=anthropic
OLLAMA_FALLBACK_MODEL=claude-haiku-4-5

# Finance tier (fin-llama3.1-8b via Ollama)
LLM_FINANCE_PROVIDER=ollama
LLM_FINANCE_MODEL=fin-llama3.1:8b-finance
OLLAMA_FINANCE_TIMEOUT=300  # optional, defaults to OLLAMA_TIMEOUT
OLLAMA_FINANCE_NUM_CTX=8192  # optional, defaults to OLLAMA_NUM_CTX


STARTING_BALANCE=100000
# Core regime + sector context + high-beta leaders (always tracked)
WATCHLIST=SPY,QQQ,IWM,DIA,TLT,GLD,XLK,XLF,XLE,TSLA,NVDA,AMD
# Non-core tickers that should always be analyst/PM eligible if they produce valid signals
PM_TRADABLE_SYMBOLS=META,MU
# Liquid candidate pool for Scout to filter by price move, volume, catalyst, technicals
SCOUT_CANDIDATES=AAPL,MSFT,META,AMZN,GOOGL,AVGO,SMCI,PLTR,COIN,MSTR,ARM,MU,INTC,NFLX
LOOP_INTERVAL_MINUTES=15

# PM candidate-ID rollout
# disabled: legacy PM only
# shadow: candidate path is evaluated without executing; legacy PM remains authoritative
# enabled: candidate-ID path is authoritative for new entries
PM_CANDIDATE_MODE=disabled
PM_BENCHMARK_CONTEXT_ENABLED=false
PM_ALIGNMENT_POLICY_MODE=disabled

# Slack report forwarding — optional, leave empty to disable
# Create a Slack bot at https://api.slack.com/apps and add chat:write scope
CEO_SLACK_BOT_TOKEN=
CEO_SLACK_CHANNEL_ID=

# Google Blogger publishing — optional, leave empty to disable
# Narratives are posted to a Blogger blog as a public/archival record
# Set up OAuth2 credentials at https://console.cloud.google.com/apis/credentials
BLOGGER_BLOG_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
